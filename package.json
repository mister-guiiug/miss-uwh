{
  "name": "miss-uwh",
  "private": true,
  "license": "MIT",
  "version": "1.0.0",
  "type": "module",
  "description": "Miss UWH — PWA de bilan comptable saisonnier pour un club de Hockey Subaquatique (Under Water Hockey). Local-first, installable, hors ligne, RBAC sécurisé via Supabase en option.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/check-bundle-budget.mjs",
    "build:analyze": "cross-env ANALYZE=1 npm run build",
    "check:bundle": "node scripts/check-bundle-budget.mjs",
    "preview": "vite preview --base /miss-uwh/",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "type-check": "tsc -b",
    "icons": "node scripts/generate-pwa-icons.mjs",
    "supabase:push": "supabase db push",
    "supabase:link": "supabase link",
    "supabase:types": "supabase gen types typescript --linked > src/backend/database.types.ts",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@mister-guiiug/dev-wpa-config": "^2.0.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "typescript": "~6.0.3",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "lucide-react": "^1.17.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "tailwindcss": "^4.2.2",
    "zod": "^4.0.0",
    "zustand": "^5.0.12"
  }
}
